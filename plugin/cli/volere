#!/bin/bash
# Volere Agentic Framework CLI
# Usage: volere <command> [options]
#
# Commands:
#   init        Scaffold a new project with DAL profile
#   new         Create a new requirement card
#   validate    Run all verification checks
#   trace       Show traceability matrix
#   coverage    Show fit criteria coverage
#   impact      Show change impact for a requirement
#   review      Generate team review prompt
#   check-docs  Check documentation staleness
#   clean       Remove process artifacts from docs/
#   graph       Interactive requirement graph visualization

set -euo pipefail

VOLERE_DIR="$(cd "$(dirname "$0")/.." && pwd)"
SCHEMA_DIR="$VOLERE_DIR/schema"
TEMPLATE_DIR="$VOLERE_DIR/templates"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

# Detect project root
find_project_root() {
  local dir="$PWD"
  while [ "$dir" != "/" ]; do
    if [ -d "$dir/.volere" ] || [ -d "$dir/docs/requirements" ]; then
      echo "$dir"
      return
    fi
    dir="$(dirname "$dir")"
  done
  echo "$PWD"
}

PROJECT_ROOT=$(find_project_root)
REQS_DIR="$PROJECT_ROOT/docs/requirements"

# ============================================================
# volere init
# ============================================================
cmd_init() {
  local dal="${1:-C}"
  local NO_HOOKS=0

  # Strip -- prefix if present
  dal="${dal#--dal=}"
  dal="${dal#--dal }"

  # Parse --dal flag
  while [ $# -gt 0 ]; do
    case "$1" in
      --dal) dal="$2"; shift 2 ;;
      --dal=*) dal="${1#--dal=}"; shift ;;
      --no-hooks) NO_HOOKS=1; shift ;;
      *) shift ;;
    esac
  done

  echo "Scaffolding project with DAL-$dal profile..."
  echo ""

  # Create directories
  mkdir -p docs/requirements
  mkdir -p .volere

  # Copy templates
  if [ ! -f "docs/requirements/README.md" ]; then
    cp "$TEMPLATE_DIR/project-scaffold/docs/requirements/README.md" docs/requirements/
    echo "  Created: docs/requirements/README.md"
  else
    echo "  Exists:  docs/requirements/README.md"
  fi

  if [ ! -f "docs/requirements/context.yaml" ]; then
    cp "$TEMPLATE_DIR/project-scaffold/docs/requirements/context.yaml" docs/requirements/
    echo "  Created: docs/requirements/context.yaml (edit stakeholders, scope, glossary)"
  else
    echo "  Exists:  docs/requirements/context.yaml"
  fi

  if [ ! -f ".volere/profile.yaml" ]; then
    cp "$TEMPLATE_DIR/project-scaffold/.volere/profile.yaml" .volere/
    # Set the requested DAL
    sed -i '' "s/^dal: C/dal: $dal/" .volere/profile.yaml 2>/dev/null || \
    sed -i "s/^dal: C/dal: $dal/" .volere/profile.yaml 2>/dev/null || true
    echo "  Created: .volere/profile.yaml (DAL-$dal)"
  else
    echo "  Exists:  .volere/profile.yaml"
  fi

  if [ ! -f ".volere/boundaries.yaml" ]; then
    cp "$TEMPLATE_DIR/project-scaffold/.volere/boundaries.yaml" .volere/
    echo "  Created: .volere/boundaries.yaml (edit module rules)"
  else
    echo "  Exists:  .volere/boundaries.yaml"
  fi

  # Install hooks (default: yes, opt-out with --no-hooks)
  echo ""
  if [ "$NO_HOOKS" -eq 1 ]; then
    echo "  Hooks: skipped (--no-hooks). Not recommended for DAL-C+."
  elif [ -d ".git" ]; then
    "$VOLERE_DIR/hooks/install.sh" --hooks-dir ".git/hooks" 2>/dev/null || \
      echo "  Hooks: install manually with: $VOLERE_DIR/hooks/install.sh"
  else
    echo "  Hooks: not a git repo — install hooks after git init"
  fi

  # Copy .claude/settings.json for SessionStart hook
  if [ ! -f ".claude/settings.json" ]; then
    mkdir -p .claude
    cp "$TEMPLATE_DIR/project-scaffold/.claude/settings.json" .claude/
    echo "  Created: .claude/settings.json (SessionStart coverage hook)"
  else
    echo "  Exists:  .claude/settings.json"
  fi

  echo ""
  echo "Next steps:"
  echo "  1. Edit docs/requirements/context.yaml (stakeholders, scope, glossary)"
  echo "  2. Run: volere new --type functional (write your first requirement)"
  echo "  3. Add the Session Start snippet to your CLAUDE.md:"
  echo "     cat $VOLERE_DIR/templates/project-scaffold/CLAUDE.md.snippet"
  echo "  4. Edit CLAUDE.md and ARCHITECTURE.md with project details"
  echo ""
  echo "Run: volere validate to check project health"
}

# ============================================================
# volere new
# ============================================================
cmd_new() {
  local type="functional"
  local serves=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --type) type="$2"; shift 2 ;;
      --type=*) type="${1#--type=}"; shift ;;
      --serves) serves="$2"; shift 2 ;;
      --serves=*) serves="${1#--serves=}"; shift ;;
      *) shift ;;
    esac
  done

  # Determine prefix from type
  local prefix="UR"
  case "$type" in
    business-use-case) prefix="BUC" ;;
    product-use-case) prefix="PUC" ;;
    technical-constraint) prefix="TC" ;;
    *) prefix="UR" ;;
  esac

  # Find next number
  local max=0
  for f in "$REQS_DIR"/${prefix}-*.yaml; do
    if [ -f "$f" ]; then
      local num=$(basename "$f" | grep -oE '[0-9]{3}' | head -1)
      num=$((10#$num))  # Remove leading zeros
      if [ "$num" -gt "$max" ]; then
        max=$num
      fi
    fi
  done
  local next=$((max + 1))
  local id=$(printf "%s-%03d" "$prefix" "$next")
  local filename="$REQS_DIR/$id.yaml"

  mkdir -p "$REQS_DIR"

  # Select template
  local template
  case "$type" in
    business-use-case) template="$TEMPLATE_DIR/business-use-case.yaml" ;;
    product-use-case) template="$TEMPLATE_DIR/product-use-case.yaml" ;;
    technical-constraint) template="$TEMPLATE_DIR/technical-constraint.yaml" ;;
    *) template="$TEMPLATE_DIR/requirement-card.yaml" ;;
  esac

  cp "$template" "$filename"

  # Replace the template ID with the actual ID
  sed -i '' "s/^id: ${prefix}-001/id: $id/" "$filename" 2>/dev/null || \
  sed -i "s/^id: ${prefix}-001/id: $id/" "$filename" 2>/dev/null || true

  # Set type
  sed -i '' "s/^type: .*/type: $type/" "$filename" 2>/dev/null || \
  sed -i "s/^type: .*/type: $type/" "$filename" 2>/dev/null || true

  # Set serves if provided (for TCs)
  if [ -n "$serves" ]; then
    sed -i '' "s/^serves: \[\]/serves: [$serves]/" "$filename" 2>/dev/null || \
    sed -i "s/^serves: \[\]/serves: [$serves]/" "$filename" 2>/dev/null || true
  fi

  # Set today's date
  local today=$(date +%Y-%m-%d)
  sed -i '' "s/date: \"\"/date: \"$today\"/" "$filename" 2>/dev/null || \
  sed -i "s/date: \"\"/date: \"$today\"/" "$filename" 2>/dev/null || true

  echo "Created: $filename"
  echo ""
  echo "  Edit the file to fill in: title, description, rationale, fit_criteria"
  echo "  Validate: volere validate --file $filename"
}

# ============================================================
# volere validate
# ============================================================
cmd_validate() {
  local file=""
  local suspects=0

  while [ $# -gt 0 ]; do
    case "$1" in
      --file) file="$2"; shift 2 ;;
      --file=*) file="${1#--file=}"; shift ;;
      --suspects) suspects=1; shift ;;
      *) shift ;;
    esac
  done

  local errors=0
  local warnings=0

  echo -e "${CYAN}Volere Validation${NC} — $(basename "$PROJECT_ROOT")"
  echo ""

  # Single file mode
  if [ -n "$file" ]; then
    "$VOLERE_DIR/validate.sh" "$file"
    return $?
  fi

  # Schema validation
  echo "  Schema validation:"
  local card_count=0
  local card_pass=0
  for f in "$REQS_DIR"/*.yaml; do
    [ -f "$f" ] || continue
    # Skip context.yaml
    [ "$(basename "$f")" = "context.yaml" ] && continue
    card_count=$((card_count + 1))
    if "$VOLERE_DIR/validate.sh" "$f" > /dev/null 2>&1; then
      card_pass=$((card_pass + 1))
    else
      echo -e "    ${RED}✗${NC} $(basename "$f")"
      "$VOLERE_DIR/validate.sh" "$f" 2>&1 | grep "✗" | sed 's/^/      /'
      errors=$((errors + 1))
    fi
  done
  if [ "$card_count" -eq 0 ]; then
    echo -e "    ${YELLOW}○${NC} No requirement cards found"
  elif [ "$card_pass" -eq "$card_count" ]; then
    echo -e "    ${GREEN}✓${NC} $card_count cards pass schema validation"
  fi

  # Context check
  echo "  Project context:"
  if [ -f "$REQS_DIR/context.yaml" ]; then
    echo -e "    ${GREEN}✓${NC} context.yaml exists"
  else
    echo -e "    ${YELLOW}⚠${NC} context.yaml missing"
    warnings=$((warnings + 1))
  fi

  # Profile check
  echo "  DAL profile:"
  if [ -f "$PROJECT_ROOT/.volere/profile.yaml" ]; then
    local dal=$(grep "^dal:" "$PROJECT_ROOT/.volere/profile.yaml" 2>/dev/null | awk '{print $2}')
    echo -e "    ${GREEN}✓${NC} profile.yaml (DAL-$dal)"
  else
    echo -e "    ${YELLOW}⚠${NC} No .volere/profile.yaml"
    warnings=$((warnings + 1))
  fi

  # Project constitution checks
  echo "  Project constitution:"
  for doc in CLAUDE.md ARCHITECTURE.md README.md; do
    if [ -f "$PROJECT_ROOT/$doc" ]; then
      echo -e "    ${GREEN}✓${NC} $doc exists"
    else
      echo -e "    ${YELLOW}⚠${NC} $doc missing"
      warnings=$((warnings + 1))
    fi
  done

  # Staleness check
  if [ -f "$PROJECT_ROOT/ARCHITECTURE.md" ]; then
    local arch_age=$(stat -f %m "$PROJECT_ROOT/ARCHITECTURE.md" 2>/dev/null || stat -c %Y "$PROJECT_ROOT/ARCHITECTURE.md" 2>/dev/null || echo 0)
    local latest_code=$(find "$PROJECT_ROOT" -name "*.go" -o -name "*.js" -o -name "*.ts" -o -name "*.py" 2>/dev/null | \
      grep -v node_modules | grep -v vendor | \
      xargs stat -f %m 2>/dev/null | sort -rn | head -1 || echo 0)
    if [ "$latest_code" -gt 0 ] && [ "$arch_age" -gt 0 ]; then
      local diff=$(( (latest_code - arch_age) / 86400 ))
      if [ "$diff" -gt 30 ]; then
        echo -e "    ${YELLOW}⚠${NC} ARCHITECTURE.md is ${diff} days stale"
        warnings=$((warnings + 1))
      fi
    fi
  fi

  # Hooks check
  echo "  Hooks:"
  if [ -f "$PROJECT_ROOT/.git/hooks/pre-commit" ] && grep -q "Volere\|check-secrets" "$PROJECT_ROOT/.git/hooks/pre-commit" 2>/dev/null; then
    echo -e "    ${GREEN}✓${NC} check-secrets installed"
  else
    echo -e "    ${YELLOW}⚠${NC} check-secrets not installed"
    warnings=$((warnings + 1))
  fi
  if [ -f "$PROJECT_ROOT/.git/hooks/commit-msg" ] && grep -q "Volere\|check-traceability" "$PROJECT_ROOT/.git/hooks/commit-msg" 2>/dev/null; then
    echo -e "    ${GREEN}✓${NC} check-traceability installed"
  else
    echo -e "    ${YELLOW}⚠${NC} check-traceability not installed"
    warnings=$((warnings + 1))
  fi

  # Suspect links
  echo "  Suspect links:"
  if [ -f "$PROJECT_ROOT/.volere/suspects.yaml" ] && grep -q "status: suspect" "$PROJECT_ROOT/.volere/suspects.yaml" 2>/dev/null; then
    local suspect_count=$(grep -c "status: suspect" "$PROJECT_ROOT/.volere/suspects.yaml")
    echo -e "    ${RED}✗${NC} $suspect_count unresolved suspect link(s)"
    if [ "$suspects" -eq 1 ]; then
      errors=$((errors + 1))
    else
      warnings=$((warnings + 1))
    fi
  else
    echo -e "    ${GREEN}✓${NC} No suspect links"
  fi

  # Summary
  echo ""
  local total=$((errors + warnings))
  if [ "$total" -eq 0 ]; then
    echo -e "  ${GREEN}✓ All checks pass${NC}"
  else
    echo -e "  ${RED}$errors errors${NC}, ${YELLOW}$warnings warnings${NC}"
  fi

  return "$errors"
}

# ============================================================
# volere trace
# ============================================================
cmd_trace() {
  echo -e "${CYAN}Traceability Matrix${NC} — $(basename "$PROJECT_ROOT")"
  echo ""

  local total=0
  local traced=0
  local gaps=0

  for f in "$REQS_DIR"/*.yaml; do
    [ -f "$f" ] || continue
    [ "$(basename "$f")" = "context.yaml" ] && continue

    local id=$(grep "^id:" "$f" | head -1 | awk '{print $2}')
    local title=$(grep "^title:" "$f" | head -1 | sed 's/^title: //' | sed 's/^"//' | sed 's/"$//')
    [ -z "$id" ] && continue

    total=$((total + 1))

    # Find code files referencing this ID
    local code_files=$(grep -rl "$id" "$PROJECT_ROOT" \
      --include="*.go" --include="*.js" --include="*.ts" --include="*.py" --include="*.sh" --include="*.rs" \
      2>/dev/null | grep -v node_modules | grep -v _test | grep -v ".test." | grep -v "test-hooks\|test_" | grep -v vendor | head -5 || true)

    # Find test files referencing this ID
    local test_files=$(grep -rl "$id" "$PROJECT_ROOT" \
      --include="*_test.go" --include="*.test.js" --include="*.test.ts" --include="*.spec.*" \
      --include="*test*.sh" --include="*_test.py" --include="*_test.rs" \
      2>/dev/null | grep -v node_modules | head -5 || true)

    echo -e "  ${CYAN}$id${NC}  $title"

    if [ -n "$code_files" ]; then
      echo "$code_files" | while IFS= read -r cf; do
        echo -e "    ├── Code: ${cf#$PROJECT_ROOT/}"
      done
    else
      echo -e "    ├── Code: ${YELLOW}(no references found)${NC}"
    fi

    if [ -n "$test_files" ]; then
      echo "$test_files" | while IFS= read -r tf; do
        echo -e "    ├── Test: ${tf#$PROJECT_ROOT/}"
      done
      traced=$((traced + 1))
    else
      echo -e "    ├── Test: ${RED}(no tests found)${NC}"
      gaps=$((gaps + 1))
    fi

    echo -e "    └── Status: $([ -n "$test_files" ] && echo -e "${GREEN}✓ TRACED${NC}" || echo -e "${RED}✗ GAP${NC}")"
    echo ""
  done

  echo "Summary: $total requirements"
  echo -e "  Traced: ${GREEN}$traced${NC} ($(( traced * 100 / (total > 0 ? total : 1) ))%)"
  echo -e "  Gaps:   ${RED}$gaps${NC} ($(( gaps * 100 / (total > 0 ? total : 1) ))%)"
}

# ============================================================
# volere coverage
# ============================================================
cmd_coverage() {
  local dimension=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --dimension) dimension="$2"; shift 2 ;;
      --dimension=*) dimension="${1#--dimension=}"; shift ;;
      *) shift ;;
    esac
  done

  echo -e "${CYAN}Fit Criteria Coverage${NC} — $(basename "$PROJECT_ROOT")"
  echo ""

  local total_criteria=0
  local covered=0
  local uncovered=0
  local total_cards=0
  local total_tests=0

  for f in "$REQS_DIR"/*.yaml; do
    [ -f "$f" ] || continue
    [ "$(basename "$f")" = "context.yaml" ] && continue

    local id=$(grep "^id:" "$f" | head -1 | awk '{print $2}')
    local dal=$(grep "^dal:" "$f" | head -1 | awk '{print $2}')
    [ -z "$id" ] && continue

    # Count fit criteria dimensions in this card
    local dims=$(grep "^    criterion:" "$f" 2>/dev/null | wc -l | tr -d ' ')
    [ "$dims" -eq 0 ] && dims=1  # At least one assumed

    # If filtering by dimension, check if this card has it
    if [ -n "$dimension" ]; then
      if ! grep -q "^  $dimension:" "$f" 2>/dev/null; then
        continue
      fi
      dims=1
    fi

    total_criteria=$((total_criteria + dims))
    total_cards=$((total_cards + 1))

    # Check if tests reference this ID (count all matching test files)
    local test_files=$(grep -rl "$id" "$PROJECT_ROOT" \
      --include="*_test.go" --include="*.test.js" --include="*.test.ts" --include="*.spec.*" \
      --include="*test*.sh" --include="*_test.py" --include="*_test.rs" \
      2>/dev/null | grep -v node_modules || true)
    local test_count=0
    if [ -n "$test_files" ]; then
      test_count=$(echo "$test_files" | wc -l | tr -d ' ')
    fi
    total_tests=$((total_tests + test_count))

    if [ -n "$test_files" ]; then
      covered=$((covered + dims))
      echo -e "  ${GREEN}✓${NC} $id (DAL-$dal): tested"
    else
      uncovered=$((uncovered + dims))
      echo -e "  ${RED}✗${NC} $id (DAL-$dal): ${RED}not tested${NC}"
    fi
  done

  echo ""
  if [ "$total_criteria" -gt 0 ]; then
    echo "  Coverage: $covered/$total_criteria ($(( covered * 100 / total_criteria ))%)"
  else
    echo "  No fit criteria found"
  fi
  echo -e "  Uncovered: ${RED}$uncovered${NC}"

  # Cards-to-tests ratio (UR-019)
  if [ "$total_cards" -gt 0 ]; then
    local ratio=$(awk "BEGIN {printf \"%.1f\", $total_tests / $total_cards}")
    echo "  Ratio: 1:$ratio ($total_cards cards, $total_tests tests)"
    local low=$(awk "BEGIN {print ($total_tests / $total_cards < 1.2) ? 1 : 0}")
    if [ "$low" -eq 1 ]; then
      echo -e "  ${YELLOW}⚠ Low ratio — check for single-dimensional fit criteria.${NC}"
    fi
  fi
}

# ============================================================
# volere impact
# ============================================================
cmd_impact() {
  local target_id="${1:?Usage: volere impact <ID>}"

  echo -e "${CYAN}Impact Analysis${NC} — $target_id"
  echo ""

  # Find the requirement file
  local target_file=$(grep -rl "^id: $target_id$" "$REQS_DIR" 2>/dev/null | head -1)
  if [ -z "$target_file" ]; then
    echo -e "  ${RED}Error: $target_id not found in $REQS_DIR${NC}"
    return 1
  fi

  local title=$(grep "^title:" "$target_file" | head -1 | sed 's/^title: //' | sed 's/^"//' | sed 's/"$//')
  echo "  $target_id: $title"
  echo ""

  # Find direct dependents (requirements that depend_on or serve this ID)
  echo "  Direct dependents:"
  local found_deps=0
  for f in "$REQS_DIR"/*.yaml; do
    [ -f "$f" ] || continue
    [ "$(basename "$f")" = "context.yaml" ] && continue
    [ "$f" = "$target_file" ] && continue

    local dep_id=$(grep "^id:" "$f" | head -1 | awk '{print $2}')

    if grep -q "$target_id" "$f" 2>/dev/null; then
      local dep_title=$(grep "^title:" "$f" | head -1 | sed 's/^title: //' | sed 's/^"//' | sed 's/"$//')
      local relation=""
      grep -q "depends_on:.*$target_id" "$f" && relation="depends_on"
      grep -q "serves:.*$target_id" "$f" && relation="serves"
      grep -q "source:.*$target_id" "$f" && relation="derived from"
      grep -q "decomposed_to:.*$target_id" "$f" && relation="parent of"
      echo -e "    ├── $dep_id ($relation) — $dep_title"
      found_deps=1
    fi
  done
  [ "$found_deps" -eq 0 ] && echo "    (none)"

  # Find affected code
  echo ""
  echo "  Affected code:"
  local code_files=$(grep -rl "$target_id" "$PROJECT_ROOT" \
    --include="*.go" --include="*.js" --include="*.ts" --include="*.py" \
    2>/dev/null | grep -v node_modules | grep -v _test | grep -v ".test." | grep -v vendor || true)
  if [ -n "$code_files" ]; then
    echo "$code_files" | while IFS= read -r cf; do
      echo "    ├── ${cf#$PROJECT_ROOT/}"
    done
  else
    echo "    (no code references)"
  fi

  # Find affected tests
  echo ""
  echo "  Affected tests:"
  local test_files=$(grep -rl "$target_id" "$PROJECT_ROOT" \
    --include="*_test.go" --include="*.test.js" --include="*.test.ts" --include="*.spec.*" \
    2>/dev/null | grep -v node_modules || true)
  if [ -n "$test_files" ]; then
    echo "$test_files" | while IFS= read -r tf; do
      echo "    ├── ${tf#$PROJECT_ROOT/}"
    done
  else
    echo -e "    ${RED}(no tests reference this requirement)${NC}"
  fi

  echo ""
  echo "  If $target_id changes:"
  echo "    → Review all direct dependents for consistency"
  echo "    → Re-run affected tests"
  echo "    → Update affected code if needed"
  echo ""
  echo "  Mark dependents as suspect:"
  echo "    volere impact --mark $target_id"
}

cmd_impact_mark() {
  local source_id="${1:?Usage: volere impact --mark <ID>}"
  local suspect_sh="$VOLERE_DIR/cli/suspect.sh"

  # Find dependents and mark them suspect
  for f in "$REQS_DIR"/*.yaml; do
    [ -f "$f" ] || continue
    [ "$(basename "$f")" = "context.yaml" ] && continue

    local dep_id=$(grep "^id:" "$f" | head -1 | awk '{print $2}')
    [ "$dep_id" = "$source_id" ] && continue

    if grep -q "$source_id" "$f" 2>/dev/null; then
      "$suspect_sh" mark "$dep_id" --reason "$source_id changed" --source "$source_id"
    fi
  done
}

cmd_impact_resolve() {
  local id="${1:?Usage: volere impact --resolve <ID>}"
  "$VOLERE_DIR/cli/suspect.sh" resolve "$id"
}

# ============================================================
# volere review
# ============================================================
cmd_review() {
  local card_count=$(ls "$REQS_DIR"/*.yaml 2>/dev/null | grep -v context.yaml | wc -l | tr -d ' ')
  local review_mode=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --coherence) review_mode="coherence"; shift ;;
      *) shift ;;
    esac
  done

  echo -e "${CYAN}Review Requirements${NC}"
  echo ""
  echo "  Project: $(basename "$PROJECT_ROOT")"
  echo "  Requirements: $card_count"
  echo ""

  # Explicit coherence review (bypass minimum card count)
  if [ "$review_mode" = "coherence" ]; then
    echo "  Type: Coherence Review — check for contradictions across requirement set"
    echo "  Team: 1 agent (pairwise comparison of descriptions, rationales, fit criteria)"
    echo ""
    echo "  Use the review-requirements skill in Claude Code to run the coherence check."
    return
  fi

  if [ "$card_count" -lt 5 ]; then
    echo "  < 5 requirements — use write-requirement skill to improve individual cards."
    echo "  Full team review is most effective with 5+ requirements."
    return
  fi

  # Detect review type
  if [ ! -d "$REQS_DIR/reviews" ]; then
    echo "  Type: Full Review (Pass 1) — no previous reviews found"
    echo "  Team: 5 agents (CTO, test engineer, security, devops, synthesis)"
  elif [ -n "$(find "$REQS_DIR" -name '*.yaml' -newer "$REQS_DIR/reviews/synthesis.md" 2>/dev/null | head -1)" ]; then
    echo "  Type: Validation Review (Pass 1.5) — requirements changed since last review"
    echo "  Team: 3 agents (CTO, test engineer, synthesis)"
  else
    echo "  Type: Requirements are current. Run trace for codebase mapping."
    echo "  Team: 4 agents (code tracer, test tracer, frontend tracer, synthesis)"
  fi

  echo ""
  echo "  Use the review-requirements skill in Claude Code to generate the team prompt."
  echo "  Or copy a proven prompt from: docs/team-prompt-ur-review.md"
}

# ============================================================
# volere check-docs
# ============================================================
cmd_check_docs() {
  echo -e "${CYAN}Documentation Staleness${NC} — $(basename "$PROJECT_ROOT")"
  echo ""

  # Constitution docs (always checked)
  local docs="ARCHITECTURE.md README.md CLAUDE.md"

  # Extra docs from profile.yaml
  if [ -f "$PROJECT_ROOT/.volere/profile.yaml" ]; then
    local extra=$(grep -A 100 "^docs:" "$PROJECT_ROOT/.volere/profile.yaml" 2>/dev/null | \
      grep "^  - " | sed 's/^  - //' | tr -d '"' || true)
    docs="$docs $extra"
  fi

  # Find most recent source change
  local latest_source=0
  for ext in yaml sh md js ts go py rs; do
    local candidate=$(find "$PROJECT_ROOT" -name "*.$ext" \
      -not -path "*/node_modules/*" -not -path "*/.git/*" \
      -not -path "*/reviews/*" -not -path "*/docs/*" \
      2>/dev/null | xargs stat -f %m 2>/dev/null | sort -rn | head -1 || \
      find "$PROJECT_ROOT" -name "*.$ext" \
      -not -path "*/node_modules/*" -not -path "*/.git/*" \
      -not -path "*/reviews/*" -not -path "*/docs/*" \
      -exec stat -c %Y {} \; 2>/dev/null | sort -rn | head -1 || echo 0)
    [ "${candidate:-0}" -gt "$latest_source" ] && latest_source="$candidate"
  done

  local stale=0
  local checked=0

  for doc in $docs; do
    local doc_path="$PROJECT_ROOT/$doc"
    if [ ! -f "$doc_path" ]; then
      echo -e "  ${YELLOW}○${NC} $doc (not found)"
      continue
    fi

    checked=$((checked + 1))
    local doc_mtime=$(stat -f %m "$doc_path" 2>/dev/null || stat -c %Y "$doc_path" 2>/dev/null || echo 0)

    if [ "$latest_source" -gt 0 ] && [ "$doc_mtime" -gt 0 ]; then
      local days=$(( (latest_source - doc_mtime) / 86400 ))
      if [ "$days" -gt 7 ]; then
        echo -e "  ${RED}✗${NC} $doc — ${RED}STALE${NC} ($days days)"
        stale=$((stale + 1))
      else
        echo -e "  ${GREEN}✓${NC} $doc — CURRENT"
      fi
    else
      echo -e "  ${GREEN}✓${NC} $doc — CURRENT"
    fi
  done

  echo ""
  echo "  Checked: $checked docs, $stale stale"

  if [ "$stale" -gt 0 ]; then
    echo ""
    echo "  Run coherence review to verify content accuracy."
  fi
}

# ============================================================
# volere clean
# ============================================================
cmd_clean() {
  local do_rm=0
  while [ $# -gt 0 ]; do
    case "$1" in
      --rm) do_rm=1; shift ;;
      *) shift ;;
    esac
  done

  echo -e "${CYAN}Process Artifacts${NC} — $(basename "$PROJECT_ROOT")"
  echo ""

  local found=0
  local removed=0
  local skipped=0

  # Check a single artifact path
  check_artifact() {
    local path="$1" source="$2"
    local full="$PROJECT_ROOT/$path"
    [ -e "$full" ] || return 0
    local rel="$path"
    found=$((found + 1))

    if [ "$do_rm" -eq 1 ]; then
      # Check if uncommitted (dirty in git)
      if ! git -C "$PROJECT_ROOT" diff --quiet -- "$rel" 2>/dev/null || \
         ! git -C "$PROJECT_ROOT" diff --cached --quiet -- "$rel" 2>/dev/null || \
         git -C "$PROJECT_ROOT" ls-files --others --exclude-standard -- "$rel" 2>/dev/null | grep -q .; then
        echo -e "  ${YELLOW}⚠${NC} $rel — skipped (uncommitted changes)"
        skipped=$((skipped + 1))
      else
        rm -rf "$full"
        echo -e "  ${GREEN}✓${NC} $rel — removed"
        removed=$((removed + 1))
      fi
    else
      local age="unknown"
      if [ -f "$full" ]; then
        local mtime=$(stat -f %m "$full" 2>/dev/null || stat -c %Y "$full" 2>/dev/null || echo 0)
        local now=$(date +%s)
        [ "$mtime" -gt 0 ] && age="$(( (now - mtime) / 86400 )) days old"
      elif [ -d "$full" ]; then
        age="directory"
      fi
      printf "  %-40s %-16s (%s)\n" "$rel" "$age" "$source"
    fi
  }

  # discovery-to-delivery
  check_artifact "docs/problem.md" "discovery-to-delivery"
  check_artifact "docs/brief.md" "discovery-to-delivery"
  check_artifact "docs/options" "discovery-to-delivery"
  check_artifact "docs/spec.md" "discovery-to-delivery"
  check_artifact "docs/decisions.md" "discovery-to-delivery"

  # superpowers
  check_artifact "docs/superpowers" "superpowers"
  check_artifact ".superpowers" "superpowers"

  # execution artifacts (glob)
  for f in "$PROJECT_ROOT"/docs/execution-*.md; do
    [ -f "$f" ] || continue
    check_artifact "${f#$PROJECT_ROOT/}" "execution"
  done
  for f in "$PROJECT_ROOT"/docs/team-prompt-*.md; do
    [ -f "$f" ] || continue
    check_artifact "${f#$PROJECT_ROOT/}" "execution"
  done

  echo ""
  if [ "$found" -eq 0 ]; then
    echo "  No process artifacts found."
  elif [ "$do_rm" -eq 1 ]; then
    echo "  $removed removed, $skipped skipped"
  else
    echo "  $found process artifacts found (git history preserves all removed files)"
    echo "  Run: volere clean --rm"
  fi
}

# ============================================================
# volere graph
# ============================================================
cmd_graph() {
  local output=""
  local no_open=0

  while [ $# -gt 0 ]; do
    case "$1" in
      --output) output="$2"; shift 2 ;;
      --output=*) output="${1#--output=}"; shift ;;
      --no-open) no_open=1; shift ;;
      *) shift ;;
    esac
  done

  [ -z "$output" ] && output="/tmp/volere-graph.html"

  local template="$VOLERE_DIR/cli/graph-template.html"
  if [ ! -f "$template" ]; then
    echo -e "${RED}Error: graph-template.html not found at $template${NC}"
    return 1
  fi

  # Build JSON nodes array
  local nodes="["
  local first_node=1
  for f in "$REQS_DIR"/*.yaml; do
    [ -f "$f" ] || continue
    [ "$(basename "$f")" = "context.yaml" ] && continue

    local id=$(grep "^id:" "$f" | head -1 | awk '{print $2}')
    local title=$(grep "^title:" "$f" | head -1 | sed 's/^title: //' | sed 's/^"//' | sed 's/"$//')
    local type_raw=$(grep "^type:" "$f" | head -1 | awk '{print $2}')
    local dal=$(grep "^dal:" "$f" | head -1 | awk '{print $2}')
    local status=$(grep "^status:" "$f" | head -1 | awk '{print $2}')
    [ -z "$id" ] && continue

    # Map type to prefix
    local type_prefix
    case "$type_raw" in
      business-use-case) type_prefix="BUC" ;;
      product-use-case) type_prefix="PUC" ;;
      technical-constraint) type_prefix="TC" ;;
      *) type_prefix="UR" ;;
    esac

    # Extract fit criteria summaries
    local fit_json="{"
    local first_fit=1
    local in_fit=0
    local current_dim=""
    while IFS= read -r line; do
      if echo "$line" | grep -q "^fit_criteria:"; then
        in_fit=1; continue
      fi
      if [ "$in_fit" -eq 1 ]; then
        # End of fit_criteria block
        if echo "$line" | grep -qE "^[a-z_]+:" && ! echo "$line" | grep -q "^    "; then
          echo "$line" | grep -qE "^  [a-z]" || break
        fi
        # Dimension header (e.g., "  user:")
        if echo "$line" | grep -qE "^  [a-z_]+:$"; then
          current_dim=$(echo "$line" | sed 's/^  //' | sed 's/://');
        fi
        # Criterion value
        if echo "$line" | grep -q "^    criterion:"; then
          local crit=$(echo "$line" | sed 's/^    criterion: //' | sed 's/^"//' | sed 's/"$//' | sed "s/'/\\\\\'/g" | sed 's/"/\\"/g')
          [ "$first_fit" -eq 0 ] && fit_json="$fit_json,"
          fit_json="$fit_json\"$current_dim\":\"$crit\""
          first_fit=0
        fi
      fi
    done < "$f"
    fit_json="$fit_json}"

    [ "$first_node" -eq 0 ] && nodes="$nodes,"
    nodes="$nodes{\"id\":\"$id\",\"type\":\"$type_prefix\",\"title\":\"$title\",\"dal\":\"$dal\",\"status\":\"$status\",\"fit_criteria\":$fit_json}"
    first_node=0
  done
  nodes="$nodes]"

  # Build JSON edges array
  local edges="["
  local first_edge=1
  for f in "$REQS_DIR"/*.yaml; do
    [ -f "$f" ] || continue
    [ "$(basename "$f")" = "context.yaml" ] && continue

    local from_id=$(grep "^id:" "$f" | head -1 | awk '{print $2}')
    [ -z "$from_id" ] && continue

    # Extract relationship arrays
    for rel_type in depends_on serves decomposed_to cross_verify conflicts; do
      local targets=$(grep -A 20 "^${rel_type}:" "$f" 2>/dev/null | grep "^  - " | sed 's/^  - //' | tr -d ' ')
      for target in $targets; do
        [ "$first_edge" -eq 0 ] && edges="$edges,"
        edges="$edges{\"from\":\"$from_id\",\"to\":\"$target\",\"type\":\"$rel_type\"}"
        first_edge=0
      done
    done
  done
  edges="$edges]"

  local json="{\"nodes\":$nodes,\"edges\":$edges}"

  # Inject JSON into template
  # Use awk to avoid sed issues with special characters in JSON
  awk -v data="$json" '{gsub(/\{\{DATA\}\}/, data); print}' "$template" > "$output"

  echo -e "${CYAN}Requirement Graph${NC} — $(basename "$PROJECT_ROOT")"
  echo ""
  local node_count=$(echo "$json" | grep -o '"id"' | wc -l | tr -d ' ')
  local edge_count=$(echo "$json" | grep -o '"from"' | wc -l | tr -d ' ')
  echo "  Nodes: $node_count requirements"
  echo "  Edges: $edge_count relationships"
  echo "  Output: $output"

  if [ "$no_open" -eq 0 ] && command -v open >/dev/null 2>&1; then
    open "$output"
  fi
}

# ============================================================
# Main
# ============================================================
case "${1:-help}" in
  init)     shift; cmd_init "$@" ;;
  new)      shift; cmd_new "$@" ;;
  validate) shift; cmd_validate "$@" ;;
  trace)    shift; cmd_trace "$@" ;;
  coverage) shift; cmd_coverage "$@" ;;
  impact)
    shift
    case "${1:---show}" in
      --mark) shift; cmd_impact_mark "$@" ;;
      --resolve) shift; cmd_impact_resolve "$@" ;;
      --suspects) "$VOLERE_DIR/cli/suspect.sh" check ;;
      --auto) "$VOLERE_DIR/cli/suspect.sh" auto ;;
      *) cmd_impact "$@" ;;
    esac
    ;;
  review)     shift; cmd_review "$@" ;;
  check-docs) shift; cmd_check_docs "$@" ;;
  clean)      shift; cmd_clean "$@" ;;
  graph)      shift; cmd_graph "$@" ;;
  help|--help|-h)
    echo "Volere Agentic Framework CLI"
    echo ""
    echo "Usage: volere <command> [options]"
    echo ""
    echo "Commands:"
    echo "  init [--dal C]              Scaffold project with DAL profile"
    echo "  new [--type functional]     Create new requirement card"
    echo "  validate [--file F]         Run verification checks"
    echo "  trace                       Show traceability matrix"
    echo "  coverage [--dimension D]    Show fit criteria coverage"
    echo "  impact <ID>                 Show change impact for a requirement"
    echo "  impact --mark <ID>          Mark dependents as suspect"
    echo "  impact --resolve <ID>       Mark suspect link as resolved"
    echo "  impact --suspects           Check for unresolved suspect links"
    echo "  impact --auto               Auto-detect suspects from git changes"
    echo "  review [--coherence]        Detect review type and show guidance"
    echo "  check-docs                 Check documentation staleness"
    echo "  clean [--rm]               Remove process artifacts from docs/"
    echo "  graph [--output F]          Interactive requirement graph"
    echo ""
    echo "Examples:"
    echo "  volere init --dal B"
    echo "  volere new --type technical-constraint --serves UR-003"
    echo "  volere validate"
    echo "  volere coverage --dimension security"
    echo "  volere impact UR-003"
    ;;
  *)
    echo "Unknown command: $1"
    echo "Run 'volere help' for usage"
    exit 1
    ;;
esac
